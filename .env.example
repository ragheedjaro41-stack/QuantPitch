# ============================================================
# QuantPitch — Required Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real secrets.

# -- Supabase (Frontend) --
# From Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# Supabase Edge Function Secrets (NOT in .env — set in Dashboard)
# ============================================================
# These are Deno secrets, not Vite env vars. Set them in:
#   Supabase Dashboard > Edge Functions > Secrets
#
# API_FOOTBALL_KEY — Required for fixtures, results, teams,
#   standings, players sync (sync-fixtures, sync-results,
#   sync-teams, sync-standings, sync-players).
#   Sign up: https://www.api-football.com/
#
# ODDS_API_KEY — Required for live bookmaker odds (sync-odds).
#   LIVE_PICK is blocked until this key exists.
#   Sign up: https://the-odds-api.com/

# ============================================================
# Production Deployment (Docker)
# ============================================================
# Vite bakes VITE_* vars into the JS bundle at BUILD TIME.
# Pass them as Docker build args:
#
#   docker build \
#     --build-arg VITE_SUPABASE_URL=https://<project>.supabase.co \
#     --build-arg VITE_SUPABASE_ANON_KEY=<anon-key> \
#     -t quantpitch:latest .
#
#   docker run -p 80:80 quantpitch:latest
#
# Healthcheck: curl http://localhost/healthz
